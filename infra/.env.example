# Artademi yerel altyapı ortam değişkenleri (ÖRNEK)
# Bu dosyayı kopyalayıp `infra/.env` oluştur ve gerçek/güvenli değerlerle doldur:
#   cp .env.example .env
# infra/.env ASLA git'e girmez; .env.example girer.

# ---------- PostgreSQL ----------
# Hem uygulama (artademi) hem de Keycloak DB'si bu kullanıcıyla erişilir.
POSTGRES_USER=artademi
POSTGRES_PASSWORD=degistir-guvenli-bir-parola

# ---------- Keycloak yönetici (bootstrap) ----------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=degistir-guvenli-bir-parola
