# Artademi backend — yerel ortam değişkenleri (ÖRNEK)
# Kopyala ve gerçek değerlerle doldur:  cp .env.example .env
# backend/.env git'e GİRMEZ; backend/.env.example girer.

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/artademi
SPRING_DATASOURCE_USERNAME=artademi
