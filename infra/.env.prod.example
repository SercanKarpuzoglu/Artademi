# .env.prod.example — Artademi PRODUCTION sırlar ŞABLONU
#
# KULLANIM:
#   1) cp .env.prod.example .env.prod
#   2) Aşağıdaki BÜTÜN <...> alanlarını GÜÇLÜ değerlerle doldur.
#   3) .env.prod'u ASLA git'e ekleme (.gitignore'da olmalı).
#
# GÜÇLÜ ŞİFRE ÜRETMEK İÇİN (sunucuda çalıştır, çıktıyı kopyala):
#   openssl rand -base64 24
#
# ⚠️ Yerel "artademi_local_2026" gibi ZAYIF şifreleri PROD'DA KULLANMA.

# ───────── PostgreSQL ─────────
POSTGRES_USER=artademi
POSTGRES_PASSWORD=<GUCLU_DB_SIFRESI_BURAYA>

# ───────── Keycloak yönetici (bootstrap) ─────────
# İlk admin kullanıcısı. Bu, web uygulamasının login'i DEĞİL —
# Keycloak Admin Console (auth.artademi.com) girişi.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<GUCLU_KEYCLOAK_ADMIN_SIFRESI_BURAYA>

# ───────── Backend → Keycloak Admin API (service account) ─────────
# Bu secret'i prod Keycloak'ta artademi-backend client'ı oluşturunca alacaksın.
# Realm import sonrası Keycloak Console'dan kopyalayıp buraya yapıştır.
KEYCLOAK_ADMIN_CLIENT_SECRET=<KEYCLOAK_BACKEND_CLIENT_SECRET_BURAYA>
